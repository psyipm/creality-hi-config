#!/bin/sh /etc/rc.common
# procd init script for the MJPEG bridge.
# Deployed to /etc/init.d/mjpeg_server.

START=99
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/share/moonraker-env/bin/python3 /mnt/UDISK/mjpeg_server.py
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
