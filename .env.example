# Copy this file to `.env` and fill in your values.
# `deploy.sh` sources `.env` if present. CLI arg to deploy.sh overrides PRINTER_IP.

# Printer IP or hostname. Substituted into moonraker.conf at deploy time
# (placeholder: __PRINTER_HOST__) and used as the SSH target.
PRINTER_IP=192.168.1.100

# Spoolman server, used by Moonraker's [spoolman] section.
# Substituted into moonraker.conf at deploy time (placeholder: __SPOOLMAN_HOST__).
# Include scheme and port if non-default, e.g. http://spoolman.local:7912
SPOOLMAN_URL=http://spoolman.local

# Self-hosted Obico server URL. Substituted into moonraker-obico.cfg at deploy
# time (placeholder: __OBICO_URL__).
OBICO_URL=http://obico.local

# Per-printer auth token written by the `link` step on the printer. Leave
# empty for the first deploy; after running the link step (CHANGES.md §3),
# read the token from /mnt/UDISK/printer_data/config/moonraker-obico.cfg on
# the printer and paste it here so future deploys stay idempotent. If this is
# empty and the printer's cfg already has a non-empty auth_token, deploy.sh
# refuses to overwrite the remote cfg — see safety check in deploy.sh.
OBICO_AUTH_TOKEN=
